{
  "name": "@n8n-dev/n8n-nodes-yodlee",
  "version": "1.0.0",
  "description": "This file describes the Yodlee Platform APIs using the swagger notation. You can use this swagger file to generate client side SDKs to the Yodlee Platform APIs for many different programming langua..",
  "license": "MIT",
  "homepage": "https://n8n-code.github.io/n8n-dev/#/n8n-nodes-yodlee",
  "keywords": [
    "n8n",
    "n8n-community-node",
    "n8n-node",
    "n8n-community-node-package",
    "openapi",
    "swagger",
    "api",
    "automation",
    "workflow",
    "yodlee"
  ],
  "author": {
    "name": "kelvinzer0",
    "email": ""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/n8n-code/n8n-nodes-yodlee.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/YodleeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Yodlee/Yodlee.node.js"
    ]
  },
  "dependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "*",
    "prettier": "3.8.3",
    "release-it": "20.2.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
